{
  "Arena": {
    "Id": "sp500",
    "DisplayName": "S&P 500"
  },
  "ConnectionStrings": {
    "AlphaLab": "Data Source=E:\\AlphaLabDatabase\\{Arena.Id}\\alphalab.db"
  },
  "Worker": {
    "Mode": "OnDemand",
    "ProcessThroughLastCompletedSessionOnly": true,
    "DrainQueuedJobsOnLaunch": true,
    "HeartbeatSeconds": 30,
    "StaleRunThresholdSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
