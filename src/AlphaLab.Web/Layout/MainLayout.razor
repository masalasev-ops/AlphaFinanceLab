@inherits LayoutComponentBase
@inject ArenaEntry Arena

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @* finding 121: the header renders the active arena's DisplayName — no external tutorial links. *@
            <span class="arena-header">Active arena: <strong>@Arena.DisplayName</strong> (@Arena.Id)</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
